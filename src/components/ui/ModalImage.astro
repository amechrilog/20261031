---
import { Image } from "astro:assets";

interface Props {
  src: ImageMetadata;
  alt: string;
}

const { src, alt } = Astro.props;
const modalId = `modal-${Math.random().toString(36).substring(2, 9)}`;
---

<button
  type="button"
  class="w-full overflow-hidden rounded-lg cursor-zoom-in transition-transform hover:opacity-80"
  onclick={`document.getElementById('${modalId}').showModal()`}
>
  <Image src={src} alt={alt} class="w-full h-auto object-cover" />
</button>

<dialog
  id={modalId}
  class="bg-transparent p-0 w-screen h-screen max-w-none max-h-none open:flex items-center justify-center backdrop:bg-black/80 backdrop:backdrop-blur-sm overflow-visible"
>
  <button
    type="button"
    class="absolute inset-0 w-full h-full bg-transparent cursor-default z-0"
    onclick={`document.getElementById('${modalId}').close()`}
    tabindex="-1"
    aria-hidden="true"></button>

  <div
    class="relative flex flex-col items-center z-10 max-w-[90vw] max-h-[90vh]"
  >
    <button
      type="button"
      class="absolute -top-12 right-0 text-white text-4xl font-bold hover:text-gray-300 z-50 cursor-pointer"
      onclick={`document.getElementById('${modalId}').close()`}
      aria-label="閉じる"
    >
      ×
    </button>

    <Image
      src={src}
      alt={alt}
      class="max-w-full max-h-[85vh] object-contain rounded"
    />
  </div>
</dialog>

<style>
  dialog {
    border: none;
  }

  /* アニメーション設定 */
  dialog[open] {
    animation: zoom 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  dialog[open]::backdrop {
    animation: fade 0.3s ease-out;
  }

  @keyframes zoom {
    from {
      transform: scale(0.95);
      opacity: 0;
    }
    to {
      transform: scale(1);
      opacity: 1;
    }
  }
  @keyframes fade {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
</style>
